# API credentials for Zerodha
ZERODHA_API_KEY=your_api_key_here
ZERODHA_API_SECRET=your_api_secret_here
ZERODHA_ACCESS_TOKEN=your_access_token_here

# Trading parameters
DEFAULT_INITIAL_BALANCE=100000
MODEL_SAVE_PATH=models
DATA_PATH=data/historical/{}.csv
RESULTS_SAVE_PATH=results

# Transaction cost parameters
BROKERAGE_INTRADAY=0.0003
BROKERAGE_DELIVERY=0.0
STT_INTRADAY=0.00025
STT_DELIVERY=0.001
EXCHANGE_TXN_CHARGE=0.0000345
SEBI_CHARGES=0.000001
STAMP_DUTY=0.00015
GST=0.18

# Tax Settings
SHORT_TERM_CAPITAL_GAINS_TAX=0.15
LONG_TERM_CAPITAL_GAINS_TAX=0.10
LONG_TERM_THRESHOLD_DAYS=365

# Position and risk management parameters
MAX_POSITION_SIZE_PCT=0.40
MAX_OPEN_POSITIONS=8
MAX_TRADES_PER_DAY=10
DAILY_LOSS_LIMIT_PCT=0.035
DAILY_PROFIT_TARGET_PCT=0.10
MAX_DRAWDOWN_ALLOWED=0.15

# Trading mode configurations
SWING_TRADING_MODE=True
USE_MARKET_REGIME=True
USE_BOLLINGER_BREAKOUTS=True
USE_RSI_FILTER=True
USE_VOLUME_FILTER=True
USE_PROFIT_TRAILING=True
USE_MULTIPLE_TIMEFRAMES=True

# Data fetching parameters
HISTORICAL_LOOKBACK_DAYS=365
TICKS_LOOKBACK_MINUTES=30
REALTIME_UPDATE_INTERVAL=60
CANDLE_TIMEFRAME=5minute

# System operation settings
LOG_LEVEL=INFO
DB_PATH=data/trading.db
ENABLE_NOTIFICATIONS=True
ENABLE_DASHBOARD=True
DASHBOARD_PORT=8050

# Reinforcement Learning model parameters
RL_ENABLED=True
RL_MODEL_UPDATE_FREQUENCY=7
RL_TRAINING_TIMESTEPS=300000
BATCH_SIZE=2048
LEARNING_RATE=0.00003