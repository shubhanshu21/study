# API Keys
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret
ZERODHA_TOTP_SECRET=your_zerodha_totp_secret
ZERODHA_REDIRECT_URL=https://127.0.0.1/login

# Trading Parameters
DEFAULT_INITIAL_BALANCE=100000
SYMBOLS=ASIANPAINT,BAJFINANCE

# Risk Management
MAX_POSITION_SIZE_PCT=0.40
MAX_OPEN_POSITIONS=8
MAX_TRADES_PER_DAY=10
DAILY_LOSS_LIMIT_PCT=0.035
DAILY_PROFIT_TARGET_PCT=0.10
MAX_DRAWDOWN_ALLOWED=0.15

# Trading Modes
SWING_TRADING_MODE=True
USE_MARKET_REGIME=True
USE_BOLLINGER_BREAKOUTS=True
USE_RSI_FILTER=True
USE_VOLUME_FILTER=True
USE_PROFIT_TRAILING=True
USE_MULTIPLE_TIMEFRAMES=True

# Transaction Costs
BROKERAGE_INTRADAY=0.0003
BROKERAGE_DELIVERY=0.0
STT_INTRADAY=0.00025
STT_DELIVERY=0.001
EXCHANGE_TXN_CHARGE=0.0000345
SEBI_CHARGES=0.000001
STAMP_DUTY=0.00015
GST=0.18

# Market Timing
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=15
MARKET_CLOSE_HOUR=15
MARKET_CLOSE_MINUTE=30
AVOID_FIRST_MINUTES=15
AVOID_LAST_MINUTES=15
TIMEZONE=Asia/Kolkata

# Scheduler Settings
DATA_UPDATE_INTERVAL=60
TRADING_DECISION_INTERVAL=300
POSITION_CHECK_INTERVAL=60

# Email Notifications
ENABLE_EMAIL_NOTIFICATIONS=False
EMAIL_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENTS=your_email@gmail.com

# Telegram Notifications
ENABLE_TELEGRAM_NOTIFICATIONS=False
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id